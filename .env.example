SESSION_DRIVER=file
DB_CONNECTION=sqlite
APP_NAME="Arlian6A1 Inventory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://inventaris.localhost

# Database Connection (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@ep-random-string.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Prisma API Service Config
PRISMA_API_URL=http://prisma-api:3000
PRISMA_API_TOKEN=

# Traefik Routing Configuration
TRAEFIK_HOST=inventaris.localhost
TRAEFIK_API_HOST=api.inventaris.localhost
TRAEFIK_DASHBOARD_HOST=traefik.localhost

# Cloudinary Storage Configuration (Optional, falls back to local storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
